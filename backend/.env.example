# MQTT broker already running on the Raspberry Pi.
# For TLS verification this must match the Mosquitto certificate SAN/CN.
# If the certificate is issued for the Raspberry Pi LAN IP, use that IP here.
DPF_MQTT_HOST=CHANGE_ME_CERT_HOST_OR_IP
DPF_MQTT_PORT=8883
DPF_MQTT_TLS=true
DPF_MQTT_USERNAME=
DPF_MQTT_PASSWORD=
DPF_MQTT_CA_FILE=
DPF_MQTT_CLIENT_ID=dpf-backend-ingestor
DPF_DEVICE_ID=dpf-tracker

# PostgreSQL will be introduced in the database stage.
DPF_DATABASE_URL=postgresql://dpf_backend:dpf_backend@localhost:5432/dpf_backend

# API defaults.
DPF_API_HOST=127.0.0.1
DPF_API_PORT=8080
